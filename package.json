{
  "name": "saucedemo-playwright",
  "version": "1.0.0",
  "description": "End-to-end test suite for saucedemo.com built with Playwright + TypeScript",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:demo": "SLOW_MO=600 playwright test --project=chromium --headed --workers=1 --retries=1",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:mobile": "playwright test --project=tablet-ipad --project=mobile-chrome --project=mobile-safari",
    "test:defects": "playwright test tests/known-defects.spec.ts",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
